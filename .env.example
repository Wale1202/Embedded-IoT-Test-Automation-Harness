# Copy to .env and adjust for your environment.

# HTTP server
PORT=3000

# PostgreSQL connection
DATABASE_URL=postgres://harness:harness@localhost:5432/harness

# A device is swept to "offline" if it has not sent telemetry
# within this many seconds (offline-sweep endpoint).
OFFLINE_THRESHOLD_SECONDS=60

# Soft anomaly thresholds. Telemetry crossing these is still accepted
# and stored, but a warning event is logged.
STALE_TIMESTAMP_SECONDS=300     # device timestamp older than this -> stale
CLOCK_SKEW_FUTURE_SECONDS=60    # device timestamp this far ahead -> skew
BATTERY_LOW_PCT=15              # battery_level below this -> low battery
SIGNAL_WEAK_DBM=-100            # signal_strength weaker than this -> weak link
TEMP_HIGH_C=85                  # temperature above this -> overheating
